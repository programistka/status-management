{
  "name": "status-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "server": "cd server && pnpm run dev",
    "client": "cd client && pnpm run dev",
    "dev": "concurrently \"pnpm run server\" \"pnpm run client\"",
    "install:all": "pnpm install --prefix server && pnpm install --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
